# ─────────────────────────────────────────────────────────────
# MakanWell secrets template — COPY this file to .env.local and
# fill in the real values. .env.local is gitignored.
# ─────────────────────────────────────────────────────────────

# OpenAI API key — required for AI voice chat (WebSocket server)
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Optional: override WebSocket endpoint for production voice server
# VITE_WEBSOCKET_ENDPOINT=wss://your-voice-api.example.com/ws

# Anthropic API key — optional fallback for legacy REST chat (api/chat.js)
# Get yours at https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Places API key — get yours at https://console.cloud.google.com → Places API
# No VITE_ prefix: read only by api/places.js, never sent to the browser.
GOOGLE_PLACES_API_KEY=your-google-places-api-key-here

# For production: set all the above in the Vercel dashboard
# (Project → Settings → Environment Variables), not in any committed file.
