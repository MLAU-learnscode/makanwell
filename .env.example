# ─────────────────────────────────────────────────────────────
# MakanWell secrets template — COPY this file to .env.local and
# fill in the real value. .env.local is gitignored; this file is
# committed so teammates know what to set.
# ─────────────────────────────────────────────────────────────

# Anthropic API key — get yours at https://console.anthropic.com → API Keys
# IMPORTANT: name has NO "VITE_" prefix on purpose. A VITE_ prefix would
# bundle the key into the browser JS where anyone could read it. This var is
# read ONLY by the serverless function in api/chat.js (process.env), so the
# key never reaches the client.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI API key — used by /api/voice/* (Whisper, TTS, answer parsing)
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# For production: set this same variable in the Vercel dashboard
# (Project → Settings → Environment Variables), not in any committed file.
